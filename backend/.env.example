# ===========================================
# PROJECT 2027 BACKEND — Environment Variables
# ===========================================

# MongoDB
MONGO_URI=

# Server
PORT=5000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Fallback (used if ALLOWED_ORIGINS is not set)
VITE_FRONTEND_URL=http://localhost:5173

# Admin Auth
ADMIN_EMAIL=
ADMIN_PASSWORD=
SECRET_KEY=

# Advocacy Guide
ADVOCACY_GUIDE_URL=

# SMTP (cPanel email)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Report Download
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
REPORT_TOKEN_EXPIRY=48h
